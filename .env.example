NODE_ENV=development
PORT=8080
HOST=127.0.0.1
PUBLIC_BASE_URL=http://localhost:8080

# Comma-separated list of origins allowed to call the public API in addition
# to per-widget Bubble allowed_domains. Use only for local/dev operations.
GLOBAL_ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080

# ElevenLabs server-side credentials. Never expose this key to embed.js.
ELEVENLABS_API_KEY=
ELEVENLABS_SIGNED_URL_ENDPOINT=https://api.elevenlabs.io/v1/convai/conversation/get-signed-url

# Bubble server-to-server workflow config. Leave BUBBLE_WORKFLOW_URL blank to use local mock data.
BUBBLE_WORKFLOW_URL=
BUBBLE_API_TOKEN=
BUBBLE_ANALYTICS_URL=

RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
